# ── MiniMax LLM (OPTIONAL) ───────────────────────────────────────────────
# Only used by the "smart expand" feature (AI-suggested travel routes).
# The app runs fully without these — /api/expand just returns an error until set.
# OpenAI-compatible endpoint; get a key at https://www.minimaxi.com/
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_MODEL_NAME=MiniMax-M2.7

# ── Server (optional overrides) ──────────────────────────────────────────
# PORT=3001
# HOST=0.0.0.0
# Comma-separated allowed origins for CORS in production (default: allow all in dev)
# CORS_ORIGINS=https://your-domain.example
